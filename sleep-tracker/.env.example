# Copy to .env (or set in Vercel → Settings → Environment Variables).
# NEVER commit .env — it's gitignored.

# Supabase — Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (SECRET, server-side only)

# Shared secret the iOS Shortcut sends as `Authorization: Bearer <secret>`.
# Generate one with: openssl rand -hex 24
SLEEP_API_SECRET=replace_with_random_hex_string
